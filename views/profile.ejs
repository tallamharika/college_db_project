<!DOCTYPE html>
<html>

<head>
<title>Student Profile</title>
<script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-gray-100 p-10">

<h1 class="text-3xl font-bold text-center mb-8">
Student Profile
</h1>

<div class="max-w-md mx-auto bg-white p-8 rounded-2xl shadow-xl text-center">

<img src="/uploads/<%= student.photo || 'default.png' %>"
class="w-40 h-40 rounded-full mx-auto object-cover mb-6 border-4 border-blue-500 shadow-lg">

<h2 class="text-3xl font-bold mb-4 text-blue-700">
<%= student.name %>
</h2>

<div class="space-y-3 text-lg">

<p>
<span class="font-bold">Age:</span>
<%= student.age %>
</p>

<p>
<span class="font-bold">Branch:</span>
<%= student.branch %>
</p>

<p>
<span class="font-bold">CGPA:</span>
<%= student.cgpa %>
</p>

</div>

<a href="/"
class="inline-block mt-6 bg-blue-600 hover:bg-blue-700 text-white px-6 py-2 rounded-lg transition">

⬅ Back

</a>

</div>

</body>
</html>