<!DOCTYPE html>
<html>
<head>
<title>Admin Login</title>
<script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-100 flex justify-center items-center h-screen">

<form action="/login" method="POST" class="bg-white p-6 rounded shadow space-y-4">
<input type="hidden" name="_csrf" value="<%= csrfToken %>">

<h2 class="text-xl font-bold text-center">Admin Login</h2>

<input name="username" placeholder="Username" class="border p-2 w-full">
<input name="password" type="password" placeholder="Password" class="border p-2 w-full">

<button class="bg-blue-500 text-white w-full py-2 rounded">
Login
</button>

</form>

</body>
</html>
 
