<!DOCTYPE html>
<html>

<head>
<title>Student Profile</title>
<script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-gray-100 p-10">

<h1 class="text-3xl font-bold text-center mb-8">
Student Profile
</h1>

<div class="max-w-md mx-auto bg-white p-6 rounded shadow text-center">

<img src="/uploads/<%= student.photo || 'default.png' %>" 
class="w-32 h-32 rounded-full mx-auto object-cover mb-4 border">

<h2 class="text-xl font-bold mb-2"><%= student.name %></h2>

<p class="text-gray-700">Age: <%= student.age %></p>

<p class="text-gray-700">Branch: <%= student.branch %></p>

<p class="text-gray-700">CGPA: <%= student.cgpa %></p>

<a href="/" class="inline-block mt-4 bg-blue-500 text-white px-4 py-2 rounded">
Back
</a>

</div>

</body>
</html>
